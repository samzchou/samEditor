{
    "name": "api-system",
    "version": "1.0.0",
    "description": "API System with WebSocket support",
    "main": "src/app.js",
    "bin": {
        "api-system": "./src/app.js"
    },
    "scripts": {
        "start": "node --security-revert=CVE-2023-46809 src/app.js",
        "dev": "nodemon src/app.js",
        "build": "pkg .",
        "build:prepare": "node scripts/prepare-build.js",
        "build:pkg": "pkg . --config pkg.config.json",
        "build:clean": "rimraf dist",
        "build:all": "npm run build:clean && npm run build",
        "lint": "eslint src/**/*.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage"
    },
    "dependencies": {
        "@coze/api": "^1.3.5",
        "archiver": "^7.0.1",
        "argon2": "0.41.1",
        "axios": "^1.7.9",
        "bcryptjs": "^2.4.3",
        "bull": "^4.16.5",
        "captchapng": "^0.0.1",
        "cheerio": "^1.0.0",
        "compressing": "^1.10.1",
        "connect-timeout": "^1.9.0",
        "convertapi": "^1.15.0",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "crypto": "^1.0.1",
        "dotenv": "^10.0.0",
        "express": "^4.17.1",
        "express-mongo-sanitize": "^2.2.0",
        "express-rate-limit": "^7.5.0",
        "express-session": "^1.17.3",
        "express-validator": "^6.15.0",
        "fluent-ffmpeg": "^2.1.3",
        "google-auth-library": "^10.2.0",
        "jsonwebtoken": "^9.0.0",
        "jszip": "^3.10.1",
        "mathjax-node": "^1.2.1",
        "mime-types": "^2.1.35",
        "mongoose": "^8.12.0",
        "multer": "^1.4.5-lts.1",
        "multiparty": "^4.2.3",
        "mysql2": "^3.11.0",
        "node-7z": "^3.0.0",
        "node-fetch": "2.1.1",
        "node-rsa": "1.1.1",
        "nodemailer": "^6.10.0",
        "openai": "^5.10.2",
        "request-ip": "^3.3.0",
        "svg2png": "^4.1.1",
        "uuid": "8.3.1",
        "winston": "^3.8.2",
        "ws": "^8.2.3",
        "xml-js": "^1.6.11",
        "xss": "^1.0.14",
        "xss-clean": "^0.1.4"
    },
    "devDependencies": {
        "@babel/core": "^7.21.4",
        "@babel/preset-env": "^7.21.4",
        "@types/jest": "^29.5.0",
        "babel-jest": "^29.5.0",
        "eslint": "^8.38.0",
        "eslint-config-prettier": "^8.8.0",
        "eslint-plugin-jest": "^27.2.1",
        "eslint-plugin-node": "^11.1.0",
        "eslint-plugin-prettier": "^4.2.1",
        "fs-extra": "^11.3.0",
        "jest": "^29.5.0",
        "nodemon": "^2.0.15",
        "pkg": "^5.5.0",
        "prettier": "^2.8.7",
        "supertest": "^6.3.3"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "pkg": {
        "assets": [
            "public/**/*",
            ".env"
        ],
        "targets": [
            "node16-win-x64",
            "node16-linux-x64",
            "node16-macos-x64"
        ],
        "outputPath": "dist"
    },
    "jest": {
        "testEnvironment": "node",
        "coverageDirectory": "./coverage/",
        "collectCoverageFrom": [
            "src/**/*.js",
            "!src/app.js",
            "!src/config/*.js"
        ]
    },
    "nodemonConfig": {
        "ignore": [
            "public/*",
            "dist/*",
            "coverage/*",
            "node_modules/*"
        ],
        "delay": "2500"
    },
    "keywords": [
        "nodejs",
        "express",
        "mongodb",
        "redis",
        "api"
    ],
    "author": "Same.Shen",
    "license": "MIT"
}
